X:1
T:Dynamics Curve Stress Test - Every Interpolation Path
C:Moltzart
M:4/4
L:1/8
Q:1/4=108
K:Dmin
%%ENSEMBLE jitter 2
% =====================================================
% STRESS TEST: %%DYNAMICS directive
% Tests: all curve types, transition lengths, attack mult,
% rapid dynamic changes, per-voice settings, interaction
% with ENSEMBLE/PNEUMA/ARTICULATE/TRANSFORM
% =====================================================
% --- V1: Piano - Linear curve, various transitions ---
[V:1 name="Piano (linear)"]
%%MIDI channel 1
%%MIDI program 0
%%ENSEMBLE voice 0
%%ARTICULATE auto
%%DYNAMICS curve linear
%%DYNAMICS transition 8
%%DYNAMICS attack 1.2
% Test 1: pp → ff over 8 notes (basic linear crescendo)
!pp! D2F2 A2d2 | f2d2 A2F2 | !ff! D2F2 A2d2 | f2d2 A2F2 |
% Test 2: ff → pp (linear decrescendo)
!ff! D2F2 A2d2 | f2d2 A2F2 | !pp! D2F2 A2d2 | f2d2 A2F2 |
% Test 3: Rapid dynamic changes (can it keep up?)
!pp! D2F2 !ff! A2d2 | !pp! f2d2 !ff! A2F2 | !pp! D2F2 !ff! A2d2 | !pp! f2d2 !ff! A2F2 |
% Test 4: Transition 16 (very slow curve)
%%DYNAMICS transition 16
!pp! D2F2 A2d2 | f2d2 A2F2 | D2F2 A2d2 | f2d2 A2F2 |
!fff! D2F2 A2d2 | f2d2 A2F2 | D2F2 A2d2 | f2d2 A2F2 |
% Test 5: Transition 2 (very fast, nearly instant)
%%DYNAMICS transition 2
!ppp! D2F2 !fff! A2d2 | f2d2 A2F2 |
% Test 6: Transition 1 (should be essentially instant)
%%DYNAMICS transition 1
!ppp! D2 !fff! F2 A2d2 | d8 |
% --- V2: Clarinet - Exponential curve ---
[V:2 name="Clarinet (exp)"]
%%MIDI channel 2
%%MIDI program 71
%%ENSEMBLE voice 3
%%PNEUMA heartbeat 0.03
%%DYNAMICS curve exponential
%%DYNAMICS transition 8
%%DYNAMICS attack 1.3
% Test 7: Exponential crescendo (slow start, fast finish)
!pp! D2F2 A2d2 | f2d2 A2F2 | !ff! D2F2 A2d2 | f2d2 A2F2 |
% Test 8: Exponential decrescendo (fast drop, slow tail)
!ff! D2F2 A2d2 | f2d2 A2F2 | !pp! D2F2 A2d2 | f2d2 A2F2 |
% Test 9: Multiple crescendo-decrescendo waves
!pp! D2F2 A2d2 | !ff! f2d2 A2F2 | !pp! D2F2 A2d2 | !ff! f2d2 A2F2 |
!pp! D2F2 A2d2 | !ff! f2d2 A2F2 | !pp! D2F2 A2d2 | !ff! d8 |
% Test 10: Attack multiplier test (1.3 = first note 30% louder)
%%DYNAMICS attack 1.5
!pp! D2F2 A2d2 | f2d2 A2F2 | !ff! D2F2 A2d2 | d8 |
% --- V3: Strings - Logarithmic curve ---
[V:3 name="Strings (log)"]
%%MIDI channel 3
%%MIDI program 48
%%ENSEMBLE voice -4
%%PNEUMA heartbeat 0.04
%%DYNAMICS curve logarithmic
%%DYNAMICS transition 8
% Test 11: Logarithmic crescendo (fast rise, slow approach to target)
!pp! D4 F4 | A4 d4 | !ff! f4 d4 | A4 F4 |
% Test 12: Logarithmic decrescendo
!ff! D4 F4 | A4 d4 | !pp! f4 d4 | A4 F4 |
% Test 13: Long notes with curve (does it interpolate within held notes?)
!pp! D8 | F8 | !fff! A8 | d8 |
!fff! d8 | A8 | !ppp! F8 | D8 |
% Test 14: Very long transition on sustained chords
%%DYNAMICS transition 12
!pp! [DFA]8 | [DFA]8 | [DFA]8 | !fff! [DFA]8 | [DFA]8 | [DFA]8 |
% --- V4: Pad - DYNAMICS OFF (control voice) ---
[V:4 name="Pad (no dynamics)"]
%%MIDI channel 4
%%MIDI program 89
%%ENSEMBLE voice 8
%%DYNAMICS off
% Test 15: Same dynamics marks but NO curve — instant jumps for comparison
!pp! [DFA]8 | [DFA]8 | !ff! [DFA]8 | [DFA]8 |
!ff! [DFA]8 | [DFA]8 | !pp! [DFA]8 | [DFA]8 |
!pp! [DFA]8 | !ff! [DFA]8 | !pp! [DFA]8 | !ff! [DFA]8 |
[DFA]8 | [DFA]8 | [DFA]8 | [DFA]8 |
[DFA]8 | [DFA]8 |
% --- V5: Transform target - Does DYNAMICS apply to transform output? ---
[V:5 name="Transform+Dynamics"]
%%MIDI channel 5
%%MIDI program 11
%%ENSEMBLE voice 5
%%DYNAMICS curve linear
%%DYNAMICS transition 8
%%TRANSFORM source 1
%%TRANSFORM pitchshift 12
%%TRANSFORM fragment 0.5
% Test 16: Transform voice with its own DYNAMICS setting
% The fragment of V1 should have linear dynamics interpolation applied
% Even though the notes come from the transform engine
% --- V6: Drums - Does DYNAMICS affect percussion? ---
[V:6 name="Drums" clef=perc]
%%MIDI channel 10
%%MIDI drummap C 36
%%MIDI drummap D 38
%%MIDI drummap E 42
%%MIDI drummap F 46
%%ENSEMBLE voice 0
%%DYNAMICS curve linear
%%DYNAMICS transition 8
% Test 17: Drum crescendo
!pp! C2E2 D2E2 | C2E2 D2E2 | !ff! C2E2 D2E2 | C2E2 D2E2 |
% Test 18: Drum decrescendo
!ff! CEDE CEDE | CEDE CEDE | !pp! CEDE CEDE | CEDE CEDE |
C2E2 D2E2 | C2E2 D2E2 | C2E2 D2E2 | C2E2 D2E2 |
C2E2 D2E2 | C2E2 D2E2 | C2E2 D2E2 | C4 z4 |
C2E2 D2E2 | C8 |
