X:1
T:Transform Test - Per-Voice Declarations + Chaining
M:4/4
L:1/8
Q:1/4=120
K:Cmaj
% V1: Original melody — source material
[V:1 name="Original"]
%%MIDI program 0
CDEF GABc | dcBA GFED | C2E2 G2c2 | B2A2 G4 |
CDEF GABc | dcBA GFED | C2E2 G2c2 | c8 |
% V2: Retrograde + transposed up a 5th + 1 bar delay (per-voice declaration)
[V:2 name="Retrograde+5"]
%%MIDI program 0
%%ENSEMBLE voice 5
%%TRANSFORM source 1
%%TRANSFORM retrograde
%%TRANSFORM pitchshift 7
%%TRANSFORM delay 1
% V3: Inversion around middle C (per-voice declaration)
[V:3 name="Inverted"]
%%MIDI program 4
%%ENSEMBLE voice -3
%%TRANSFORM source 1
%%TRANSFORM invert
%%TRANSFORM invertaxis 60
% V4: Chained — 40% fragment of V2's retrograde (tests chaining)
[V:4 name="Ghost"]
%%MIDI program 97
%%ENSEMBLE voice 10
%%TRANSFORM source 2
%%TRANSFORM fragment 0.4
%%TRANSFORM pitchshift 12
